# Backend the Vite proxy forwards /api requests to
VITE_BACKEND_URL=http://127.0.0.1:8000

# Leave empty to use the proxy (recommended). Set a full URL only to make
# the browser call the backend directly, bypassing the proxy.
VITE_API_BASE_URL=

# Google OAuth client ID (popup sign-in). Create an OAuth "Web application"
# client at https://console.cloud.google.com/apis/credentials and add these
# Authorized JavaScript origins: http://localhost:3000 and http://127.0.0.1:3000
VITE_GOOGLE_CLIENT_ID=
